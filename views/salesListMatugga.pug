doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Sales List Matugga
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
    link(rel='stylesheet' href='/css/productList.css')

  body
    .top-nav
      .container.d-flex.justify-content-between.align-items-center
        h1.page-title Sales List
        a.btn.btn-outline-light.back-btn(href='/managerMatuggaDash') Back to Dashboard

    .container.py-4
      .list-card
        .list-header
          .list-header-content
            h3.mb-1 Sales Records - Matugga
            p.mb-0 Review, update, and manage sales transactions.
          .record-count
            span.count-label Total Records
            span.count-value= sales.length

        .table-responsive
          table#procuredTable.table.align-middle.mb-0
            thead
              tr
                th(scope='col') Produce
                th(scope='col') Type
                th(scope='col') Date
                th(scope='col') Time
                th(scope='col') Quantity (kg)
                th(scope='col') Price/Kg (UGX)
                th(scope='col') Buyer
                th(scope='col') Contact
                th(scope='col') Branch
                th(scope='col') Actions

            tbody
              if sales.length
                each sale in sales
                  tr
                    td.fw-semibold #{sale.produceName}
                    td #{sale.produceType}
                    td #{moment(sale.saleDate).format("DD-MM-YYYY")}
                    td #{sale.saleTime}
                    td #{sale.quantitySold.toLocaleString()}
                    td #{sale.pricePerKg.toLocaleString()}
                    td #{sale.buyerName}
                    td #{sale.buyerContact}
                    td
                      span.branch-badge #{sale.branchName}
                    td
                      .action-group
                        a.btn.btn-sm.btn-outline-primary(href="/updateSale/" + sale._id) Update
                        form(action="/deletesaleMatugga" method='POST' onsubmit="return confirm('Are you sure you want to delete this sale?')")
                          input(type="hidden" name="id" value=sale._id)
                          button.btn.btn-sm.btn-outline-danger(type="submit") Delete
              else
                tr
                  td.empty-state(colspan='10') No sales records found.

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js' integrity='sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz' crossorigin='anonymous')
