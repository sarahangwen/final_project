doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Product List - Maganjo
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
    link(rel='stylesheet' href='/css/productList.css')

  body
    .top-nav
      .container.d-flex.justify-content-between.align-items-center
        h1.page-title Product List
        a.btn.btn-outline-light.back-btn(href='/managerMaganjoDash') Back to Dashboard

    .container.py-4
      .list-card
        .list-header
          .list-header-content
            h3.mb-1 Procured Stock - Maganjo
            p.mb-0 Review, update, and manage stock records.
          .record-count
            span.count-label Total Records
            span.count-value= products.length

        .table-responsive
          table#procuredTable.table.align-middle.mb-0
            thead
              tr
                th(scope='col') Produce
                th(scope='col') Type
                th(scope='col') Date
                th(scope='col') Time
                th(scope='col') Tonnage (kg)
                th(scope='col') Cost (UGX)
                th(scope='col') Dealer
                th(scope='col') Branch
                th(scope='col') Contact
                th(scope='col') Selling Price (UGX)
                th(scope='col') Actions
            tbody
              if products.length
                each product in products
                  tr
                    td.fw-semibold #{product.produceName}
                    td #{product.produceType}
                    td #{moment(product.procureDate).format("DD-MM-YYYY")}
                    td #{product.procureTime}
                    td #{product.tonnage.toLocaleString()}
                    td #{product.cost.toLocaleString()}
                    td #{product.dealerName}
                    td
                      span.branch-badge #{product.branchName}
                    td #{product.contact}
                    td.fw-semibold #{product.sellPrice.toLocaleString()}
                    td
                      .action-group
                        a.btn.btn-sm.btn-outline-primary(href="/updateProduct/"+product._id) Update
                        form(action="/deleteProduct" method='POST' onsubmit="return confirm('Are you sure you want to delete this product?')")
                          input(type="hidden" name="id" value=product._id)
                          button.btn.btn-sm.btn-outline-danger(type="submit") Delete
              else
                tr
                  td.empty-state(colspan='11') No product records found.

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js' integrity='sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz' crossorigin='anonymous')
