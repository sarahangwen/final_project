doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Karibu Groceries Ltd - Home
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css", rel="stylesheet")
    link(rel='stylesheet' href='/css/home.css')

  body
    header.site-header
      .container.nav-wrap
        .brand
          span.brand-badge KGL
          span.brand-name Karibu Groceries Ltd
        nav
          ul.nav-links
            li: a(href='#home') Home
            li: a(href='#about') About
            li: a(href='#operations') Operations
            li: a(href='#rules') Rules
            li: a(href='#contact') Contact
        a.btn.btn-light.login-link(href='/login') Login

    main
      section#home.hero.fade-in
        .container
          .hero-content
            p.eyebrow KGL Management Platform
            h1 Welcome to Karibu Groceries Management System
            p.lead
              | Karibu Groceries Ltd (KGL) is a wholesale distributor of cereals and legumes including Beans, Grain Maize, Cow Peas, Groundnuts, and Soybeans. We source from trusted suppliers and farms in Maganjo and Matugga.
            .hero-actions
              a.btn.btn-primary.btn-lg(href='/login') Get Started
              a.btn.btn-outline-light.btn-lg(href='#about') Learn More

      section#about.section-block.fade-in
        .container
          h2.section-title About Us
          p.section-subtitle
            | Founded to streamline produce distribution, KGL uses technology to enhance stock control, sales tracking, and operational transparency.
          .stats-grid
            .stat-card
              h3 2
              p Operational Branches
            .stat-card
              h3 1+2
              p Manager and Sales Agents per Branch
            .stat-card
              h3 100%
              p Digitized Procurement and Sales Records

      section#operations.section-block.alt.fade-in
        .container
          h2.section-title System Operations
          .operations-grid
            article.info-card
              h3 Procurement
              p
                | Managers register new stock with produce type, dealer, quantity, branch allocation, and pricing details.
            article.info-card
              h3 Sales
              p
                | Sales agents record branch transactions, and tonnage updates automatically for accurate stock movement.
            article.info-card
              h3 Credit Sales
              p
                | Credit transactions capture complete buyer details including NIN, location, contacts, due dates, and status.
            article.info-card
              h3 Branch Structure
              p
                | Each branch operates with one manager and two sales agents for reliable day-to-day operations.

      section#rules.section-block.fade-in
        .container
          h2.section-title Key Business Rules
          ul.rules-list
            li Produce must exist in stock before it can be sold.
            li Tonnage is deducted automatically after each recorded sale.
            li Sales Agents cannot enter or modify stock records.
            li Managers are responsible for setting product prices.
            li The Director can view total sales summaries across branches.

      section#contact.section-block.fade-in
        .container
          .contact-card
            h2.section-title Contact Us
            p.section-subtitle
              | Have questions or need support? Reach out to our team anytime.
            ul.contact-list
              li
                span.label Email
                span.value info@karibugroceries.com
              li
                span.label Phone
                span.value +256-700-000000
              li
                span.label Address
                span.value Kampala, Uganda

    // Scroll-to-top button
    a#scrollTopBtn(href='#') ↑

    footer
      p &copy; 2025 Karibu Groceries Ltd 

    // JavaScript Enhancements
    script.
      // Smooth scroll for anchor links
      document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
          anchor.addEventListener('click', function (e) {
            e.preventDefault();
            const target = document.querySelector(this.getAttribute('href'));
            if (target) {
              target.scrollIntoView({ behavior: 'smooth' });
            }
          });
        });

        // Scroll-to-top button behavior
        const scrollBtn = document.getElementById('scrollTopBtn');
        window.addEventListener('scroll', function () {
          if (window.scrollY > 300) {
            scrollBtn.style.display = 'block';
          } else {
            scrollBtn.style.display = 'none';
          }
        });

        scrollBtn.addEventListener('click', function (e) {
          e.preventDefault();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        // Fade-in animations on scroll
        const faders = document.querySelectorAll('.fade-in');
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('show');
            }
          });
        }, { threshold: 0.1 });

        faders.forEach(fader => observer.observe(fader));
      });
