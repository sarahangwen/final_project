doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Sales Agent Dashboard
    link(rel='stylesheet' href='/css/sales-agent-dashboard.css')
  body
    .dashboard-layout
      aside.sidebar
        .sidebar-header
          h2.sidebar-title Sales Agent
          p.sidebar-subtitle Matugga Branch
        ul
          li
            a(href='/addSaleMatugga') Record Cash Sale
          li
            a(href='/addingCredit') Record Credit Sale
          li
            a(href='/salesHistoryMatuggaDash') My Sales History
        .sidebar-footer
          a.logout-button(href='/logout') Logout

      main.main-content
        .dashboard-container
          header
            h1 Welcome #{agentName || 'Sales Agent'}

          section.summary-cards
            .card
              p.card-label Total Cash Sales
              p.card-value UGX #{Number(totalAmount || 0).toLocaleString()}
            .card
              p.card-label Total Credit Sales
              p.card-value UGX #{Number(totalCredit || 0).toLocaleString()}

          section.panel
            h3.panel-title Recent Cash Sales
            .table-wrap
              table
                thead
                  tr
                    th Produce
                    th Tonnage (kg)
                    th Amount Paid
                    th Date
                tbody
                  if cashSales && cashSales.length
                    each sale in cashSales
                      tr
                        td #{sale.produceName}
                        td #{Number(sale.tonnage || 0).toLocaleString()}
                        td UGX #{Number(sale.amountPaid || 0).toLocaleString()}
                        td #{sale.date ? sale.date.toDateString() : '-'}
                  else
                    tr
                      td(colspan="4") No cash sales available.

          section.panel
            h3.panel-title Outstanding Credit Sales
            .table-wrap
              table
                thead
                  tr
                    th Buyer
                    th Produce
                    th Amount Due
                    th Due Date
                tbody
                  if creditSales && creditSales.length
                    each credit in creditSales
                      tr
                        td #{credit.buyerName}
                        td #{credit.produceName}
                        td UGX #{Number(credit.amountDue || 0).toLocaleString()}
                        td #{credit.dueDate ? credit.dueDate.toDateString() : '-'}
                  else
                    tr
                      td(colspan="4") No outstanding credit sales.

    script.
      const currentPath = window.location.pathname;
      const sidebarLinks = document.querySelectorAll('.sidebar a');
      sidebarLinks.forEach((link) => {
        const href = link.getAttribute('href');
        if (href && href === currentPath) {
          link.classList.add('active');
        }
      });

    //- footer
