doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport', content='width=device-width, initial-scale=1')
    title Record Sale - Maganjo
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css', rel='stylesheet')
    link(rel='stylesheet', href='/css/sale.css')
  body
    - const values = formData || {}
    .top-nav
      .container.d-flex.justify-content-between.align-items-center
        h1.page-title Record Sale
        a.btn.btn-outline-light.back-btn(href='/salesAgentMaganjoDash') Back to Dashboard

    .container.py-4
      .form-wrapper
        .form-header
          h3.mb-1 New Sale Entry
          p.mb-0 Enter complete and accurate sale details before submitting.

        if errorMessage
          .alert.alert-danger(role='alert')= errorMessage

        if validationErrors && validationErrors.length
          .alert.alert-warning(role='alert')
            ul.mb-0
              each err in validationErrors
                li= err

        form#registerSaleForm.needs-validation(action='/addSaleMaganjo' method='POST' novalidate)
          .row.g-3
            .col-md-6
              label.form-label(for='produceName') Produce Name
              select#produceName.form-select(name='produceName' required)
                option(value='') Select Produce
                option(value='Maize grains' selected=values.produceName === 'Maize grains') Maize grains
                option(value='Soya beans' selected=values.produceName === 'Soya beans') Soya beans
                option(value='Cow peas' selected=values.produceName === 'Cow peas') Cow peas
                option(value='G-nuts' selected=values.produceName === 'G-nuts') G-nuts
                option(value='Maize' selected=values.produceName === 'Maize') Maize
              .invalid-feedback Please select a produce name.

            .col-md-6
              label.form-label(for='produceType') Produce Type
              select#produceType.form-select(name='produceType' required)
                option(value='') Select Type
                option(value='Legume' selected=values.produceType === 'Legume') Legume
                option(value='Cereals' selected=values.produceType === 'Cereals') Cereals
              .invalid-feedback Please select a produce type.

            .col-md-6
              label.form-label(for='saleDate') Date of Sale
              input#saleDate.form-control(type='date' name='saleDate' value=values.saleDate || '' required)
              .invalid-feedback Please enter a valid sale date.

            .col-md-6
              label.form-label(for='saleTime') Time of Sale
              input#saleTime.form-control(type='time' name='saleTime' value=values.saleTime || '' required)
              .invalid-feedback Please enter a valid sale time.

            .col-md-6
              label.form-label(for='quantitySold') Quantity Sold (kg)
              input#quantitySold.form-control(type='number' name='quantitySold' min='1' step='1' value=values.quantitySold || '' required)
              .invalid-feedback Quantity must be at least 1kg.

            .col-md-6
              label.form-label(for='pricePerKg') Price per Kg (UGX)
              input#pricePerKg.form-control(type='number' name='pricePerKg' min='1000' step='1' value=values.pricePerKg || '' required)
              .invalid-feedback Price per kg must be at least UGX 1,000.

            .col-md-6
              label.form-label(for='buyerName') Buyer Name
              input#buyerName.form-control(type='text' name='buyerName' minlength='2' pattern="^[A-Za-z\s'-]{2,}$" value=values.buyerName || '' required)
              .invalid-feedback Buyer name should contain letters only and be at least 2 characters.

            .col-md-6
              label.form-label(for='buyerContact') Buyer Contact
              input#buyerContact.form-control(type='tel' name='buyerContact' pattern='^(07\d{8}|2567\d{8})$' placeholder='07XXXXXXXX or 2567XXXXXXXX' value=values.buyerContact || '' required)
              .invalid-feedback Enter a valid Ugandan phone number.

            .col-md-6
              label.form-label(for='branchName') Branch Name
              select#branchName.form-select(name='branchName' required)
                option(value='Maganjo' selected=true) Maganjo
              .invalid-feedback Branch must be Maganjo.

            .col-md-6
              label.form-label(for='paymentMode') Payment Mode
              select#paymentMode.form-select(name='paymentMode' required)
                option(value='') Select Payment Mode
                option(value='Cash' selected=values.paymentMode === 'Cash') Cash
                option(value='mobileMoney' selected=values.paymentMode === 'mobileMoney') Mobile Money
              .invalid-feedback Please select a payment mode.

          .mt-4.d-grid
            button.btn.btn-primary.btn-lg(type='submit') Save Sale Record

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js')
    script.
      const registerSaleForm = document.getElementById('registerSaleForm');
      const saleDate = document.getElementById('saleDate');
      const saleTime = document.getElementById('saleTime');
      const branchName = document.getElementById('branchName');
      const now = new Date();
      const yyyy = now.getFullYear();
      const mm = String(now.getMonth() + 1).padStart(2, '0');
      const dd = String(now.getDate()).padStart(2, '0');
      const hh = String(now.getHours()).padStart(2, '0');
      const min = String(now.getMinutes()).padStart(2, '0');
      const today = `${yyyy}-${mm}-${dd}`;

      saleDate.max = today;
      if (!saleDate.value) saleDate.value = today;
      if (!saleTime.value) saleTime.value = `${hh}:${min}`;
      branchName.value = 'Maganjo';

      registerSaleForm.addEventListener('submit', (event) => {
        const selectedDate = saleDate.value ? new Date(saleDate.value) : null;
        const currentDate = new Date(today);

        if (selectedDate && selectedDate > currentDate) {
          saleDate.setCustomValidity('Sale date cannot be in the future.');
        } else {
          saleDate.setCustomValidity('');
        }

        if (branchName.value !== 'Maganjo') {
          branchName.setCustomValidity('Branch must be Maganjo.');
        } else {
          branchName.setCustomValidity('');
        }

        if (!registerSaleForm.checkValidity()) {
          event.preventDefault();
          event.stopPropagation();
        }

        registerSaleForm.classList.add('was-validated');
      });
