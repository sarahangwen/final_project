doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Sales Per Product - Maganjo
    link(rel='stylesheet' href='/css/productList.css')
    script(src='https://cdn.jsdelivr.net/npm/chart.js')  

  body
    .top-nav
      .container.d-flex.justify-content-between.align-items-center
        h1.page-title Sales Per Product
        a.btn.btn-outline-light.back-btn(href='/managerMaganjoDash') Back to Dashboard

    .container.py-4
      .list-card
        .list-header
          .list-header-content
            h3.mb-1 Product Performance - Maganjo
            p.mb-0 Overview of stock sold per product.
          .record-count
            span.count-label Total Products
            span.count-value= products.length

        .table-responsive
          table#procuredTable.table.align-middle.mb-0
            thead
              tr
                th Product
                th Total Quantity (kg)
                th Total Sales Amount (UGX)
            tbody
              if products.length
                each product in products 
                  tr
                    td.fw-semibold #{product.produceName}
                    td #{product.tonnage.toLocaleString()}
                    td #{(product.sellPrice * product.tonnage).toLocaleString()}
              else
                tr
                  td.empty-state(colspan='3') No product sales data found.

    script.
      window.onload = function() {
        const product = #{JSON.stringify(product)};
        
