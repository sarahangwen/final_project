doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Credit Sales Management - KGL
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
    link(rel='stylesheet', href='/css/productList.css')
  body
    .top-nav
      .container.d-flex.justify-content-between.align-items-center
        h1.page-title Credit Sales Management
        a.btn.btn-outline-light.back-btn(href='/managerMatuggaDash') Back to Dashboard

    .container.py-4
      .list-card
        .list-header
          .list-header-content
            h3.mb-1 Credit Records - Matugga
            p.mb-0 Track outstanding customer credit transactions.
          .record-count
            span.count-label Total Records
            span.count-value= credits && credits.length ? credits.length : 0

        .table-responsive
          table#procuredTable.table.align-middle.mb-0
            thead
              tr
                th Buyer
                th National ID
                th Produce
                th Tonnage (kg)
                th Amount Due (UGX)
                th Due Date
                th Sales Agent
                th Status
                th Action
            tbody
              if credits && credits.length
                each credit in credits
                  tr
                    td.fw-semibold #{credit.creditBuyerName}
                    td #{credit.nationalId}
                    td #{credit.creditProduceName}
                    td #{credit.creditTonnage.toLocaleString()}
                    td #{credit.amountDue.toLocaleString()}
                    td #{new Date(credit.dueDate).toLocaleDateString()}
                    td #{credit.creditSalesAgentName}
                    td
                      span.branch-badge #{credit.status}
                    td
                      a.btn.btn-sm.btn-outline-primary(href="/updateCreditMatugga/" + credit._id) Update
              else
                tr
                  td.empty-state(colspan='9') No credit sales records found.

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js' integrity='sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz' crossorigin='anonymous')


