doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Login - KGL
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css", rel="stylesheet")
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css")
    link(rel="stylesheet", href="/css/login.css")

  body
    .login-page
      .login-shell
        .brand-panel
          .brand-badge KGL
          h1 Karibu Groceries Ltd
          p Manage stock, sales, and credit operations securely from one platform.
          ul.feature-list
            li
              i.fas.fa-check-circle
              span Branch-level sales visibility
            li
              i.fas.fa-check-circle
              span Real-time stock monitoring
            li
              i.fas.fa-check-circle
              span Credit tracking and follow-up

        .form-panel
          h2 Sign In
          p.form-subtitle Welcome back. Enter your account details to continue.

          if message && message.length
            .alert.alert-danger(role="alert")
              i.fas.fa-exclamation-circle.me-2
              = message[0]

          form(action="/login", method="POST")
            .mb-3
              label.form-label(for="email") Email Address
              input#email.form-control(type="email", name="email", placeholder="name@example.com", required)

            .mb-3
              label.form-label(for="password") Password
              .input-group
                input#password.form-control(type="password", name="password", placeholder="Enter your password", required)
                button.input-group-text(type="button" onclick="togglePassword()" aria-label="Toggle password visibility")
                  i#toggleIcon.fas.fa-eye

            button.btn.btn-primary.w-100(type="submit") Sign in

          .form-links
            a(href="/reset") Forgot password?
            span ·
            a(href="/signingup") Create an account

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js", crossorigin="anonymous")
    script.
      function togglePassword() {
        const passwordInput = document.getElementById('password');
        const icon = document.getElementById('toggleIcon');
        if (passwordInput.type === 'password') {
          passwordInput.type = 'text';
          icon.classList.remove('fa-eye');
          icon.classList.add('fa-eye-slash');
        } else {
          passwordInput.type = 'password';
          icon.classList.remove('fa-eye-slash');
          icon.classList.add('fa-eye');
        }
      }
