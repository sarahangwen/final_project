doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title KGL Manager Dashboard - Maganjo Branch 
    link(rel='stylesheet' href='/css/manager.css')
    script(src='https://cdn.jsdelivr.net/npm/chart.js')   

  body
    .dashboard-layout
      aside.sidebar
        .sidebar-header
          h2.sidebar-title KGL Dashboard
          p.sidebar-subtitle Maganjo Branch
        ul
          li
            a(href='/productMaganjo') Add Product  
          li
            a(href='/productListMaganjo') Product List
          li
            a(href='/addingSales') Record Sale
          li
            a(href='/salesListMag') View Sales List
          li
            a(href='/salesPerProductListMaganjo') sales Per Product
          li
            a(href='/creditSaleMaganjo') Record Credit Sales
          li
            a(href='/creditSalesListMaganjo') Credit Sales Management 
          li
            a#logout-button.logout-button(href='/logout') Logout

      main.main-content
        .dashboard-container
          header
            h1 Manager Dashboard
            p.dashboard-subtitle Operational summary for KGL Maganjo

          section#summary.summary-cards
            article.card
              p.card-label Total Sales (Today)
              p.card-value UGX #{totalSalesToday.toLocaleString()}
            article.card
              p.card-label Total Revenue (Monthly)
              p.card-value UGX #{totalRevenue.toLocaleString()}
            article.card
              p.card-label Outstanding Credit Payments
              p.card-value UGX #{outstandingCredits.toLocaleString()}
            article.card
              p.card-label Low Stock Alerts
              p.card-value #{lowStockCount} Items

          section.charts
            .chart-panel
              h2.chart-title Top Selling Products
              canvas#managerPieChart(style='width: 300px; height: 300px;')

      //- section#reports.reports
      //-   h2 Branch Performance
      //-   table
      //-     thead
      //-       tr
      //-         th Produce Name
      //-         th Initial Stock
      //-         th Total Sold
      //-         th Remaining Stock
      //-     tbody
      //-       if products.length
      //-         each product in products
      //-           tr
      //-             td #{product.name}
      //-             td #{product.stock}
      //-             td #{product.totalSold}
      //-             td 
      //-               if product.remainingStock < 10
      //-                 span(style="color: red;") #{product.remainingStock}
      //-               else
      //-                 | #{product.remainingStock}
      //-       else
      //-         tr
      //-           td(colspan="4") No products found.

    script.
      const productLabels = !{JSON.stringify(topSellingData.map(p => p.label))};
      const productSales = !{JSON.stringify(topSellingData.map(p => p.value))};

      const currentPath = window.location.pathname;
      const sidebarLinks = document.querySelectorAll('.sidebar a');
      sidebarLinks.forEach((link) => {
        const href = link.getAttribute('href');
        if (href && currentPath === href) {
          link.classList.add('active');
        }
      });

      const data = {
        labels: productLabels,
        datasets: [{
          label: 'Top Selling Products',
          data: productSales,
          backgroundColor: [
            '#FF6384',
            '#36A2EB',
            '#FFCE56',
            '#4BC0C0',
            '#FF9F40',
            '#9966FF',
            '#00A36C'
          ],
          borderColor: '#fff',
          borderWidth: 1
        }]
      };

      const config = {
        type: 'pie',
        data: data,
        options: {
          responsive: true,
          plugins: {
            legend: {
              position: 'top',
            },
            title: {
              display: true,
              text: 'Top Selling Products - Performance'
            }
          }
        }
      };

      const ctx = document.getElementById('managerPieChart').getContext('2d');
      new Chart(ctx, config);
